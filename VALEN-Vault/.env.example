# =====================================================================
#  VALEN — variáveis de ambiente do docker compose (Contabo)
#  Copie para .env e edite:   cp .env.example .env
# =====================================================================

# ------------- AUTENTICAÇÃO (USUÁRIO ÚNICO / ADMIN) ------------------
# Nome do Administrador (único usuário que pode logar)
VALEN_ADMIN_USER=davi

# Hash da senha do Admin (NUNCA a senha em texto puro!)
# Gere com:  cd brain && python gerar_hash.py "sua-senha-forte"
VALEN_ADMIN_PASSWORD_HASH=

# Segredo que assina os JWT — gere com:  openssl rand -hex 32
VALEN_JWT_SECRET=

# Validade do token em dias (expiração longa para CLI/Android/Desktop)
VALEN_JWT_EXPIRE_DAYS=30

# --------------- CONSELHO DE MODELOS (Banca de Conselheiros) ---------
# Baixe todos na 1ª vez:
#   docker compose exec ollama ollama pull llama3:8b
#   docker compose exec ollama ollama pull qwen2.5-coder:7b
#   docker compose exec ollama ollama pull llama3:70b
VALEN_MODELO_ROTEADOR=llama3:8b
VALEN_MODELO_FRONTEND=qwen2.5-coder:7b
VALEN_MODELO_RAPIDO=llama3:8b
VALEN_MODELO_SUPREMO=llama3:70b
